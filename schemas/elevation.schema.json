{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tdf26/elevation.schema.json",
  "title": "Per-segment elevation profile and power estimates",
  "description": "One file per segment in data/elevation/segment-NN.json. Generated by processing/elevation_profile.py.",
  "type": "object",
  "required": [
    "segment",
    "distance",
    "elevation",
    "gradient",
    "power_30kmh",
    "power_35kmh",
    "power_40kmh",
    "power_50kmh",
    "summary"
  ],
  "properties": {
    "segment": { "type": "integer", "minimum": 0 },
    "distance": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2
    },
    "elevation": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2
    },
    "gradient": {
      "type": "array",
      "items": { "type": "number" }
    },
    "power_30kmh": { "type": "array", "items": { "type": "number" } },
    "power_35kmh": { "type": "array", "items": { "type": "number" } },
    "power_40kmh": { "type": "array", "items": { "type": "number" } },
    "power_50kmh": { "type": "array", "items": { "type": "number" } },
    "summary": {
      "type": "object",
      "required": [
        "avg_gradient",
        "max_gradient",
        "elevation_gain",
        "elevation_loss",
        "avg_power_30kmh",
        "avg_power_35kmh",
        "avg_power_40kmh",
        "avg_power_50kmh",
        "estimated_time_30kmh",
        "estimated_time_35kmh",
        "estimated_time_40kmh",
        "estimated_time_50kmh",
        "time_unit"
      ],
      "properties": {
        "avg_gradient": { "type": "number" },
        "max_gradient": { "type": "number" },
        "avg_climb_gradient": { "type": "number" },
        "avg_descent_gradient": { "type": "number" },
        "max_climb_gradient": { "type": "number" },
        "max_descent_gradient": { "type": "number" },
        "elevation_gain": { "type": "number", "minimum": 0 },
        "elevation_loss": { "type": "number", "minimum": 0 },
        "avg_power_30kmh": { "type": "number" },
        "avg_power_35kmh": { "type": "number" },
        "avg_power_40kmh": { "type": "number" },
        "avg_power_50kmh": { "type": "number" },
        "estimated_time_30kmh": { "type": "string" },
        "estimated_time_35kmh": { "type": "string" },
        "estimated_time_40kmh": { "type": "string" },
        "estimated_time_50kmh": { "type": "string" },
        "time_unit": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
