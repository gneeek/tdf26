{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tdf26/image-suggestions.schema.json",
  "title": "Wikimedia image suggestions for a segment",
  "description": "Generated by processing/suggest_images.py. Manual review picks final images.",
  "type": "object",
  "required": ["segment", "towns", "climbs", "image_count", "images"],
  "properties": {
    "segment": { "type": "integer", "minimum": 1 },
    "towns": { "type": "array", "items": { "type": "string" } },
    "climbs": { "type": "array", "items": { "type": "string" } },
    "image_count": { "type": "integer", "minimum": 0 },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url", "license"],
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "full_url": { "type": "string", "format": "uri" },
          "description_url": { "type": "string", "format": "uri" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "license": { "type": "string" },
          "artist": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
