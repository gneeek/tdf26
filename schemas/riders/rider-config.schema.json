{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tdf26/riders/rider-config.schema.json",
  "title": "Rider roster, total distance, daily cap, start date",
  "type": "object",
  "required": ["riders", "totalDistance", "dailyCap", "startDate"],
  "properties": {
    "riders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "color"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        },
        "additionalProperties": true
      }
    },
    "totalDistance": { "type": "number", "exclusiveMinimum": 0 },
    "dailyCap": { "type": "number", "exclusiveMinimum": 0 },
    "startDate": { "type": "string", "format": "date" }
  },
  "additionalProperties": true
}
