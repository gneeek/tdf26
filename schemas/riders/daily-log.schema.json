{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tdf26/riders/daily-log.schema.json",
  "title": "Daily distance log per rider",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "distances"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "distances": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": { "type": "number", "minimum": 0 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
