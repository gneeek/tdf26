{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tdf26/segments.schema.json",
  "title": "Stage 9 segment metadata",
  "description": "Generated by processing/split_gpx.py. One entry per route segment.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "segment",
      "km_start",
      "km_end",
      "start_lat",
      "start_lng",
      "end_lat",
      "end_lng",
      "elevation_gain",
      "elevation_loss",
      "min_elevation",
      "max_elevation",
      "notable_points",
      "towns",
      "climbs"
    ],
    "properties": {
      "segment": { "type": "integer", "minimum": 1 },
      "km_start": { "type": "number", "minimum": 0 },
      "km_end": { "type": "number", "minimum": 0 },
      "start_lat": { "type": "number" },
      "start_lng": { "type": "number" },
      "end_lat": { "type": "number" },
      "end_lng": { "type": "number" },
      "elevation_gain": { "type": "number", "minimum": 0 },
      "elevation_loss": { "type": "number", "minimum": 0 },
      "min_elevation": { "type": "number" },
      "max_elevation": { "type": "number" },
      "notable_points": { "type": "array", "items": { "type": "string" } },
      "towns": { "type": "array", "items": { "type": "string" } },
      "climbs": { "type": "array", "items": { "type": "string" } }
    },
    "additionalProperties": true
  }
}
