{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-destructive-git.sh",
            "if": "Bash(git *)",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(source ~/.nvm/nvm.sh)",
      "Bash(nvm use --silent)",
      "Bash(npm test)",
      "Bash(npx nuxt prepare)",
      "Bash(ruff check *)",
      "Bash(curl -s *)",
      "Bash(curl -sI *)"
    ]
  }
}
